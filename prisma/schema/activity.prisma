// Activity domain — derived feed entries generated from domain events.

model Activity {
  id       String       @id @default(cuid())
  riderId  String
  type     ActivityType
  summary  String
  // Loose reference + payload for the source entity (event, journal, bike...).
  refId    String?
  metadata Json?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([riderId])
  @@index([createdAt])
}

enum ActivityType {
  JOINED
  POSTED_JOURNAL
  CREATED_EVENT
  RSVP
  COMPLETED_RIDE
  UPLOADED_PHOTO
  ADDED_BIKE
  ADDED_MODIFICATION
  LOGGED_SERVICE
  FOLLOWED_RIDER
  FAVORITED_BUILD
  CHECK_IN
  CHECK_OUT
  MISSING_CHECKOUT
  RIDER_DOWN
  RSVP_WAITLISTED
  WAITLIST_PROMOTED
  NO_SHOW
  BADGE_EARNED
  SKILL_VERIFIED
  TRUST_LEVEL_UP
  EVENT_MESSAGE
  EVENT_UPDATED
  EVENT_CANCELLED
  RIDE_REMINDER
  MAINTENANCE_DUE
  CHALLENGE_JOINED
  CHALLENGE_COMPLETED
  HAZARD_REPORTED
  MENTIONED
  COMMENTED
  TWO_WHEELS_DOWN
  EMERGENCY_CARD_VIEWED
}
