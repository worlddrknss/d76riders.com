// Direct messages — 1:1 conversations between riders who follow each other. The
// mutual-follow gate is enforced in the server actions (see canDm). A conversation
// stores its pair in canonical order (riderAId < riderBId) so the unique pair
// constraint prevents duplicate threads.

model Conversation {
  id            String   @id @default(cuid())
  riderAId      String
  riderBId      String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  riderA   Rider           @relation("ConversationRiderA", fields: [riderAId], references: [id], onDelete: Cascade)
  riderB   Rider           @relation("ConversationRiderB", fields: [riderBId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([riderAId, riderBId])
  @@index([riderAId, lastMessageAt])
  @@index([riderBId, lastMessageAt])
}

model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Rider        @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
