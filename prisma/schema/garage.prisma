// Garage domain — per-rider machines (replaces the global garage).

model Bike {
  id           String    @id @default(cuid())
  riderId      String
  name         String
  make         String
  model        String?
  year         Int?
  type         BikeType?
  engineType   String?
  enginePower  String?
  displacement String?
  boreStroke   String?

  rider  Rider         @relation(fields: [riderId], references: [id], onDelete: Cascade)
  photos GalleryItem[]
  modifications BuildModification[]
  serviceRecords ServiceRecord[]
  collectionItems BuildCollectionItem[]
  favorites BuildFavorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
}

model BuildModification {
  id          String @id @default(cuid())
  riderId     String
  bikeId      String
  title       String
  category    ModificationCategory @default(OTHER)
  cost        Float?
  mileage     Int?
  installedAt DateTime @default(now())
  notes       String?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  bike  Bike  @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  photos GalleryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
  @@index([bikeId])
  @@index([installedAt])
}

model ServiceRecord {
  id          String @id @default(cuid())
  riderId     String
  bikeId      String
  title       String
  serviceType ServiceType @default(MAINTENANCE)
  cost        Float?
  mileage     Int?
  servicedAt  DateTime @default(now())
  notes       String?

  // Optional "do this again" reminder set when logging. remindAt is when it's
  // next due; remindedAt is stamped once the maintenance-reminders cron has
  // pushed it, so it only fires once.
  remindAt   DateTime?
  remindedAt DateTime?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  bike  Bike  @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  photos GalleryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
  @@index([bikeId])
  @@index([servicedAt])
  @@index([remindAt])
}

model BuildCollection {
  id          String @id @default(cuid())
  riderId     String
  name        String
  description String?
  isPublic    Boolean @default(false)

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  items BuildCollectionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
}

model BuildCollectionItem {
  collectionId String
  bikeId       String
  addedByRiderId String

  collection BuildCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bike       Bike            @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  addedByRider Rider         @relation(fields: [addedByRiderId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@id([collectionId, bikeId])
  @@index([bikeId])
  @@index([addedByRiderId])
}

model BuildFavorite {
  riderId String
  bikeId  String

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  bike  Bike  @relation(fields: [bikeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([riderId, bikeId])
  @@index([bikeId])
}

model GearItem {
  id           String       @id @default(cuid())
  riderId      String
  category     GearCategory
  name         String
  brand        String?
  model        String?
  size         String?
  color        String?
  condition    String?
  purchaseDate DateTime?
  purchaseUrl  String?
  imageUrl     String?
  notes        String?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId, category])
  @@index([purchaseDate])
}

enum GearCategory {
  HELMET
  GLOVES
  JACKET
  PANTS
  BOOTS
  CAMERA_GEAR
  ACCESSORY
}

enum ModificationCategory {
  EXHAUST
  EXTERIOR
  SUSPENSION
  PERFORMANCE
  WHEELS_TIRES
  LIGHTING
  ELECTRICAL
  PROTECTION
  ERGONOMICS
  ENGINE
  OTHER
}

enum ServiceType {
  MAINTENANCE
  REPAIR
  INSPECTION
  UPGRADE
  OTHER
}

enum BikeType {
  NAKED
  CRUISER
  ADVENTURE
  SPORT
  TOURING
  STANDARD
  OTHER
}
