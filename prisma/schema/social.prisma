model RiderFollow {
  followerId  String
  followingId String

  follower  Rider @relation("RiderFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following Rider @relation("RiderFollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followingId])
}

// One rider blocking another. A block in either direction ends DMs between the
// pair (checked in canDm), which is how a seller silences an unwanted buyer on
// an open-contact marketplace thread.
model RiderBlock {
  blockerId String
  blockedId String

  blocker Rider @relation("RiderBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Rider @relation("RiderBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

model EventFollow {
  riderId String
  eventId String

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([riderId, eventId])
  @@index([eventId])
}

model RiderVideo {
  id       String        @id @default(cuid())
  riderId  String
  platform VideoPlatform
  url      String
  title    String?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId, platform])
}

enum VideoPlatform {
  YOUTUBE
  TIKTOK
  OTHER
}
