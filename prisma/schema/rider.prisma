// Rider domain — the public, editable rider profile.
// One Rider per authenticated User. Owns all rider-created content.

model Rider {
  id             String   @id @default(cuid())
  userId         String   @unique
  handle         String   @unique
  name           String
  location       String?
  bio            String?
  avatarUrl      String?
  coverUrl       String?
  yearsRiding    Int?
  favoriteRoad   String?
  primaryBikeId  String?
  ridesCompleted Int      @default(0)
  joinedAt       DateTime @default(now())

  // Social links
  youtubeUrl     String?
  tiktokUrl      String?
  instagramUrl   String?
  twitterUrl     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bikes          Bike[]
  buildModifications BuildModification[]
  serviceRecords ServiceRecord[]
  buildCollections BuildCollection[]
  buildCollectionItems BuildCollectionItem[]
  buildFavorites BuildFavorite[]
  gearItems GearItem[]
  videos RiderVideo[]
  following RiderFollow[] @relation("RiderFollowFollower")
  followers RiderFollow[] @relation("RiderFollowFollowing")
  followedEvents EventFollow[]
  events         RideEvent[]
  routes         Route[]
  roads          Road[]
  roadRatings    RoadRating[]
  journalEntries JournalEntry[]
  comments       Comment[]
  likes          Like[]
  rsvps          Rsvp[]
  galleryItems   GalleryItem[]
  activities     Activity[]
  reports        Report[]     @relation("ReportsSubmitted")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
