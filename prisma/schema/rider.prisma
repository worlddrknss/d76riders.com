// Rider domain — the public, editable rider profile.
// One Rider per authenticated User. Owns all rider-created content.

model Rider {
  id             String   @id @default(cuid())
  userId         String   @unique
  handle         String   @unique
  // When the handle was last changed. Null = never changed since signup, so the
  // first change is always allowed. Handles appear in profile URLs and @mentions
  // that other riders have already learned, so changes are rate-limited rather
  // than free — see HANDLE_CHANGE_DAYS in account/actions.
  handleChangedAt DateTime?
  name           String
  location       String?
  // Geocoded from `location` (best-effort, at signup or profile edit). Powers
  // "near me" sorting on events and roads. Null when location is unset or
  // couldn't be geocoded.
  latitude       Float?
  longitude      Float?
  // Preferred IANA zone. Defaults the timezone of events they create and shows
  // a "your time" hint on events happening in a different zone. Null = unset.
  timezone       String?
  // Unguessable token in the rider's personal calendar-subscription URL. Null
  // until they first ask for the link; rotating it revokes old subscriptions.
  calendarToken  String?  @unique
  bio            String?
  avatarUrl      String?
  coverUrl       String?
  // Vertical framing of the cover photo, as the object-position Y percentage.
  // 0 = align the top of the image, 100 = the bottom, 50 = centred (the default).
  // Only Y: the cover is always scaled to the full width of the card, so there
  // is never horizontal slack to pan through.
  coverPosition  Int      @default(50)
  yearsRiding    Int?
  favoriteRoad   String?
  primaryBikeId  String?
  ridesCompleted Int      @default(0)
  joinedAt       DateTime @default(now())

  // Social links
  youtubeUrl     String?
  tiktokUrl      String?
  instagramUrl   String?
  twitterUrl     String?

  // Notification routing lives in NotificationPreference — one row per
  // (category, channel) a rider has switched off. Absent means on, so a new
  // rider gets everything without a backfill and a new category or channel
  // defaults to on rather than silently off.

  // Quiet hours (Central time, 0-23). When set and the current hour falls in the
  // window, live web-push is held; those notifications arrive as a single digest
  // when the window ends (see the notification-digest Inngest cron). Null = off.
  quietHoursStart Int?
  quietHoursEnd   Int?

  // Community ambassador — a recognized club leader. Granted by admins; shows a
  // badge on the profile and lists the rider on /ambassadors.
  isAmbassador Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bikes          Bike[]
  buildModifications BuildModification[]
  serviceRecords ServiceRecord[]
  buildCollections BuildCollection[]
  buildCollectionItems BuildCollectionItem[]
  buildFavorites BuildFavorite[]
  gearItems GearItem[]
  videos RiderVideo[]
  following RiderFollow[] @relation("RiderFollowFollower")
  followers RiderFollow[] @relation("RiderFollowFollowing")
  blocking  RiderBlock[]  @relation("RiderBlockBlocker")
  blockedBy RiderBlock[]  @relation("RiderBlockBlocked")
  followedEvents EventFollow[]
  organizedEvents EventOrganizer[]
  eventCheckIns  EventCheckIn[]
  liveLocations  LiveLocation[]
  events         RideEvent[]
  emergencyCard  EmergencyCard?
  incidents          RideIncident[] @relation("IncidentSubject")
  reportedIncidents  RideIncident[] @relation("IncidentReporter")
  routes         Route[]
  roads          Road[]
  roadRatings    RoadRating[]
  hazardReports  HazardReport[]
  journalEntries JournalEntry[]
  journalMentions JournalMention[] @relation("JournalMentions")
  comments       Comment[]
  likes          Like[]
  saves          Save[]
  stories        Story[]
  spotlights     Spotlight[]
  pushSubscriptions PushSubscription[]
  conversationsA Conversation[]  @relation("ConversationRiderA")
  conversationsB Conversation[]  @relation("ConversationRiderB")
  sentMessages   DirectMessage[] @relation("DirectMessageSender")
  rsvps          Rsvp[]
  galleryItems   GalleryItem[]
  activities     Activity[]
  reports        Report[]     @relation("ReportsSubmitted")
  reportsAgainst Report[]     @relation("ReportsAgainst")
  adminIncidents AdminIncident[] @relation("AdminIncidentSubject")
  policyAcknowledgments PolicyAcknowledgment[]
  trust          RiderTrust?
  badges         RiderBadge[]
  skills         RiderSkill[]
  verifiedSkills RiderSkill[] @relation("SkillVerifier")
  referralCode   ReferralCode?
  challenges     ChallengeEntry[]
  challengesSet  Challenge[]  @relation("ChallengeCreator")
  sponsorsSubmitted Sponsor[] @relation("SponsorSubmitter")
  sponsorReviews SponsorReview[]
  rideLogs RideLog[]
  romVotes RideOfMonthVote[]
  quests         RiderQuest[]
  crews          CrewMember[]
  notificationPrefs NotificationPreference[]
  listings       Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/**
 * A single switched-off notification route.
 *
 * Stored as opt-outs rather than a full matrix: absent means enabled, so adding
 * a category or a channel turns it on for everyone instead of leaving it off
 * until each rider notices. It also keeps the table roughly empty, since most
 * riders never change these.
 */
model NotificationPreference {
  riderId  String
  /** mention | comment | rsvp | event | rideChange | reminder | weeklyRecap */
  category String
  /** push | email | inApp */
  channel  String

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([riderId, category, channel])
  @@index([riderId])
}
