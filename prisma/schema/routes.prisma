// Routes domain — Mapbox route geometry with KSU and stop waypoints.

model Route {
  id            String  @id @default(cuid())
  riderId       String
  name          String
  description   String?
  distanceMiles Float?
  // Total climb in feet, estimated from an open elevation source at save time
  // (best-effort; null when unavailable). Powers difficulty-from-elevation.
  elevationGainFt Int?
  // Mapbox GeoJSON LineString geometry for the full route.
  geometry      Json?
  ksuLat        Float?
  ksuLng        Float?

  rider     Rider      @relation(fields: [riderId], references: [id], onDelete: Cascade)
  event     RideEvent?
  road      Road?
  waypoints Waypoint[]
  hazards   HazardReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
}

model Waypoint {
  id      String       @id @default(cuid())
  routeId String
  label   String?
  type    WaypointType @default(STOP)
  lat     Float
  lng     Float
  order   Int

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

enum WaypointType {
  START
  KSU
  FUEL
  FOOD
  REST
  STOP
  END
}
