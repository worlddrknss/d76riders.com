// Journal domain — rider-authored posts with likes and comments.

model JournalEntry {
  id       String  @id @default(cuid())
  authorId String
  title    String?
  body     String

  author       Rider         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]
  likes        Like[]
  reports      Report[]
  galleryItems GalleryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

// A Comment lives on either a JournalEntry or a RideEvent.
model Comment {
  id             String  @id @default(cuid())
  authorId       String
  body           String
  journalEntryId String?
  eventId        String?

  author       Rider         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  event        RideEvent?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([journalEntryId])
  @@index([eventId])
}

model Like {
  id             String @id @default(cuid())
  riderId        String
  journalEntryId String

  rider        Rider        @relation(fields: [riderId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([riderId, journalEntryId])
}

// Reports — flagged content for moderator review.
model Report {
  id             String       @id @default(cuid())
  reporterId     String
  journalEntryId String
  reason         ReportReason
  details        String?
  status         ReportStatus @default(PENDING)
  resolvedById   String?
  resolvedAt     DateTime?

  reporter     Rider        @relation("ReportsSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  resolvedBy   User?        @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journalEntryId])
  @@index([status])
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  REMOVED
}
  @@index([journalEntryId])
}
