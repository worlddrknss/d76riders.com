// Events domain — rider-created rides with KSU details, route, RSVP, and gallery.

model RideEvent {
  id            String          @id @default(cuid())
  hostId        String
  title         String
  slug          String          @unique
  excerpt       String?         @db.VarChar(255)
  description   String?
  facebookEventUrl String?
  startsAt      DateTime
  ksuAt         DateTime?
  ksuLocation   String?
  ksuAddress    String?
  ksuLat        Float?
  ksuLng        Float?
  meetLocation  String?
  meetAddress   String?
  meetLat       Float?
  meetLng       Float?
  distanceMiles Int?
  difficulty    RideDifficulty?
  status        EventStatus     @default(UPCOMING)
  routeId       String?         @unique
  maxCapacity   Int?
  rsvpDeadline  DateTime?

  host         Rider         @relation(fields: [hostId], references: [id], onDelete: Cascade)
  route        Route?        @relation(fields: [routeId], references: [id], onDelete: SetNull)
  organizers   EventOrganizer[]
  rsvps        Rsvp[]
  checkIns     EventCheckIn[]
  followers    EventFollow[]
  comments     Comment[]
  galleryItems GalleryItem[]
  incidents    RideIncident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hostId])
  @@index([startsAt])
}

model Rsvp {
  id      String     @id @default(cuid())
  eventId String
  riderId String
  status  RsvpStatus @default(GOING)

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, riderId])
  @@index([riderId])
}

// Shared by RideEvent and Road.
enum RideDifficulty {
  BEGINNER_FRIENDLY
  INTERMEDIATE
  SCENIC
}

enum EventStatus {
  DRAFT
  UPCOMING
  COMPLETED
  CANCELLED
}

enum RsvpStatus {
  GOING
  INTERESTED
  NOT_GOING
  WAITLISTED
}

model EventOrganizer {
  id      String             @id @default(cuid())
  eventId String
  riderId String
  role    EventOrganizerRole

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, riderId])
  @@index([riderId])
}

enum EventOrganizerRole {
  HOST
  LEAD
  SWEEP
  MARSHAL
}

model EventCheckIn {
  id         String        @id @default(cuid())
  eventId    String
  riderId    String
  checkInAt  DateTime      @default(now())
  checkOutAt DateTime?
  method     CheckInMethod

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([eventId, riderId])
  @@index([riderId])
}

enum CheckInMethod {
  QR
  NFC
  MANUAL
}

// Rider Down / safety incidents raised by organizers during a ride.
model RideIncident {
  id           String    @id @default(cuid())
  eventId      String
  riderId      String // the affected rider
  reportedById String // organizer who raised the alert
  notes        String?
  locationText String?
  lat          Float?
  lng          Float?
  resolvedAt   DateTime?

  event      RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider      Rider     @relation("IncidentSubject", fields: [riderId], references: [id], onDelete: Cascade)
  reportedBy Rider     @relation("IncidentReporter", fields: [reportedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([riderId])
}
