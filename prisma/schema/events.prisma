// Events domain — rider-created rides with KSU details, route, RSVP, and gallery.

model RideEvent {
  id            String          @id @default(cuid())
  hostId        String
  title         String
  slug          String          @unique
  excerpt       String?         @db.VarChar(255)
  description   String?
  facebookEventUrl String?
  // startsAt/ksuAt/rsvpDeadline are true UTC instants; `timezone` is the IANA
  // zone the ride happens in, and the times are rendered in it. Storing the
  // instant + zone (rather than a naive wall-clock) is what lets the upcoming
  // filter and "riding today" compare against the real clock correctly.
  startsAt      DateTime
  endsAt        DateTime?
  // Organizer-set grace deadline for the community gallery: attendees can keep
  // uploading photos until this instant, after which the gallery is closed.
  // Null = no deadline (open while the ride isn't completed). Computed on read —
  // no job flips anything.
  galleryClosesAt DateTime?
  ksuAt         DateTime?
  timezone      String          @default("America/Chicago")
  ksuLocation   String?
  ksuAddress    String?
  ksuLat        Float?
  ksuLng        Float?
  meetLocation  String?
  meetAddress   String?
  meetLat       Float?
  meetLng       Float?
  distanceMiles Int?
  difficulty    RideDifficulty?
  status        EventStatus     @default(UPCOMING)
  routeId       String?         @unique
  maxCapacity   Int?
  rsvpDeadline  DateTime?
  // Surfaced on the homepage as a public highlight.
  featured      Boolean         @default(false)
  crewId        String?

  host         Rider         @relation(fields: [hostId], references: [id], onDelete: Cascade)
  route        Route?        @relation(fields: [routeId], references: [id], onDelete: SetNull)
  crew         Crew?         @relation(fields: [crewId], references: [id], onDelete: SetNull)
  sponsors     EventSponsor[]
  organizers   EventOrganizer[]
  rsvps        Rsvp[]
  checkIns     EventCheckIn[]
  liveLocations LiveLocation[]
  followers    EventFollow[]
  comments     Comment[]
  galleryItems GalleryItem[]
  romVotes     RideOfMonthVote[]
  incidents    RideIncident[]
  reports      Report[]
  adminIncidents AdminIncident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hostId])
  @@index([startsAt])
  @@index([featured])
  @@index([crewId])
}

model Rsvp {
  id      String     @id @default(cuid())
  eventId String
  riderId String
  status  RsvpStatus @default(GOING)

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, riderId])
  @@index([riderId])
}

// Shared by RideEvent and Road.
enum RideDifficulty {
  BEGINNER_FRIENDLY
  INTERMEDIATE
  SCENIC
}

enum EventStatus {
  DRAFT
  UPCOMING
  COMPLETED
  CANCELLED
}

enum RsvpStatus {
  GOING
  INTERESTED
  NOT_GOING
  WAITLISTED
}

model EventOrganizer {
  id      String             @id @default(cuid())
  eventId String
  riderId String
  role    EventOrganizerRole

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, riderId])
  @@index([riderId])
}

enum EventOrganizerRole {
  HOST
  LEAD
  SWEEP
  MARSHAL
}

model EventCheckIn {
  id         String        @id @default(cuid())
  eventId    String
  riderId    String
  checkInAt  DateTime      @default(now())
  checkOutAt DateTime?
  method     CheckInMethod

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([eventId, riderId])
  @@index([riderId])
}

enum CheckInMethod {
  QR
  NFC
  MANUAL
}

// A rider's latest live position during an event ride. Ephemeral: upserted while
// sharing (foreground only on mobile web), stale after a few minutes, cleared on
// stop / check-out. Visible only to the ride's participants + organizers.
model LiveLocation {
  id        String   @id @default(cuid())
  eventId   String
  riderId   String
  lat       Float
  lng       Float
  updatedAt DateTime @updatedAt @default(now())

  event RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([eventId, riderId])
  @@index([eventId, updatedAt])
}

// Rider Down / safety incidents raised by organizers during a ride.
model RideIncident {
  id           String    @id @default(cuid())
  eventId      String
  riderId      String // the affected rider
  reportedById String // organizer who raised the alert
  notes        String?
  locationText String?
  lat          Float?
  lng          Float?
  resolvedAt   DateTime?

  event      RideEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rider      Rider     @relation("IncidentSubject", fields: [riderId], references: [id], onDelete: Cascade)
  reportedBy Rider     @relation("IncidentReporter", fields: [reportedById], references: [id], onDelete: Cascade)
  adminIncidents AdminIncident[]

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([riderId])
}
