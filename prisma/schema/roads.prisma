// Roads domain — rider-owned featured roads with saved route data.

model Road {
  id            String          @id @default(cuid())
  riderId       String
  routeId       String?         @unique
  name          String
  slug          String          @unique
  distanceMiles Int?
  difficulty    RideDifficulty?
  scenicRating  Float?
  description   String?
  imageLabel    String?

  rider        Rider         @relation(fields: [riderId], references: [id], onDelete: Cascade)
  route        Route?        @relation(fields: [routeId], references: [id], onDelete: SetNull)
  galleryItems GalleryItem[]
  ratings      RoadRating[]
  hazards      HazardReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
}

model RoadRating {
  id      String @id @default(cuid())
  roadId  String
  riderId String
  score   Int // 1-5

  road  Road  @relation(fields: [roadId], references: [id], onDelete: Cascade)
  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roadId, riderId])
  @@index([roadId])
  @@index([riderId])
}
