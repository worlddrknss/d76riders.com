// Roads domain — rider-owned featured roads with saved route data.

model Road {
  id            String          @id @default(cuid())
  riderId       String
  routeId       String?         @unique
  name          String
  slug          String          @unique
  distanceMiles Int?
  difficulty    RideDifficulty?
  // Cached averages of RoadRating dimensions (0-5). scenicRating is legacy but
  // kept in sync. qualityScore is the blended Route Quality shown on the page.
  scenicRating     Float?
  conditionRating  Float?
  twistinessRating Float?
  qualityScore     Float?
  description   String?
  imageLabel    String?

  rider        Rider         @relation(fields: [riderId], references: [id], onDelete: Cascade)
  route        Route?        @relation(fields: [routeId], references: [id], onDelete: SetNull)
  galleryItems GalleryItem[]
  ratings      RoadRating[]
  hazards      HazardReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
}

model RoadRating {
  id      String @id @default(cuid())
  roadId  String
  riderId String
  score   Int // Scenery, 1-5 (legacy column name)
  // Added for Route Quality — road condition/pavement and twistiness, 1-5.
  condition  Int?
  twistiness Int?

  road  Road  @relation(fields: [roadId], references: [id], onDelete: Cascade)
  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roadId, riderId])
  @@index([roadId])
  @@index([riderId])
}
